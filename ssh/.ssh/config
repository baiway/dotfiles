Host archer2
  HostName login.archer2.ac.uk
  User bc1264
  IdentityFile ~/.ssh/keys/archer2/id_ed25519
  ControlMaster auto
  ControlPath ~/.ssh/connections/%h_%p_%r
  ControlPersist yes
  UseKeychain yes

Host viking
  HostName viking.york.ac.uk
  User bc1264
