#!/usr/bin/env bash
# Reconcile `packages/*.txt` against what is actually installed.
#
# Simply running `pacman -Qqen > file` would clobber comments and may write
# installed packages that I no longer want. This script instead compares the
# listed and installed sets and only ever *appends* new packages.
#
#   ./sync-packages              # report drift, change nothing
#   ./sync-packages --apply      # walk untracked packages one at a time
#   ./sync-packages --apply-all  # append every untracked package, no prompts
#
# Scope to one list with --official or --aur. Both are walked by default.
set -euo pipefail

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DOTFILES"

MODE=report
DO_OFFICIAL=0
DO_AUR=0

while (($#)); do
  case "$1" in
    --apply)     MODE=apply ;;
    --apply-all) MODE=apply-all ;;
    --official)  DO_OFFICIAL=1 ;;
    --aur)       DO_AUR=1 ;;
    -h|--help)   sed -n '2,15p' "$0" | sed 's/^# \?//'; exit 0 ;;
    *)           printf 'unknown option: %s (try --help)\n' "$1" >&2; exit 1 ;;
  esac
  shift
done
# Neither scope flag given means both.
((DO_OFFICIAL || DO_AUR)) || { DO_OFFICIAL=1; DO_AUR=1; }

log() { printf '\n\033[1;34m==>\033[0m %s\n' "$*"; }

# Same parse the bootstrap script uses, so the two can never disagree about what
# a "listed" package is.
pkglist() { grep -vE '^\s*(#|$)' "$1" | sed 's/#.*//' | tr -d ' '; }

# Append new packages with a comment prompting the user to describe what the
# new package does
MARKER='# --- unsorted (added by `sync-packages` — annotate and file these) ---'
append_pkg() {
  local file="$1" pkg="$2"
  grep -qxF "$MARKER" "$file" || printf '\n%s\n' "$MARKER" >>"$file"
  printf '%s  # TODO: describe, then move to a section above\n' "$pkg" >>"$file"
}

# A listed package can fall out of the query for three quite different reasons,
# and only two of them are a problem you can fix mechanically:
#
#   dep      installed, but marked as a dependency — invisible to `-Qqen`/`-Qqem`
#            and one orphan-sweep away from removal.
#            Fix: `pacman -D --asexplicit <package_name>`.
# 
#   misfiled installed and explicit, just not in *this* list's category — an AUR
#            package that graduated to a binary repo, or vice versa. Fix: move it.
# 
#   gone     not installed at all. Needs a human: typo, rename, or dropped.
report_missing() {
  local file="$1" removed="$2" other="$3" pkg reason dep=() misfiled=() gone=()

  [[ -n $removed ]] || return 0

  while read -r pkg; do
    reason="$(pacman -Qi "$pkg" 2>/dev/null | sed -n 's/^Install Reason *: //p')"
    case "$reason" in
      '')                            gone+=("$pkg") ;;
      'Installed as a dependency'*)  dep+=("$pkg") ;;
      *)                             misfiled+=("$pkg") ;;
    esac
  done <<<"$removed"

  if ((${#dep[@]})); then
    printf '  \033[1;33minstalled, but only as a dependency:\033[0m\n'
    printf '    %s\n' "${dep[@]}"
    printf '    fix: sudo pacman -D --asexplicit %s\n' "${dep[*]}"
  fi
  if ((${#misfiled[@]})); then
    printf '  \033[1;33mexplicitly installed, but wrong list:\033[0m\n'
    printf '    %s\n' "${misfiled[@]}"
    printf '    fix: move these to %s (with their comments)\n' "$other"
  fi
  if ((${#gone[@]})); then
    printf '  \033[1;31mlisted but not installed at all:\033[0m\n'
    printf '    %s\n' "${gone[@]}"
    printf '    (left in place — remove by hand so you keep the annotation)\n'
  fi
}

reconcile() {
  local file="$1" query="$2" label="$3" other="$4"
  local listed installed added removed count n=0 ans bulk=0

  listed="$(pkglist "$file" | sort)"
  installed="$($query | sort)"

  added="$(comm -13 <(echo "$listed") <(echo "$installed"))"
  removed="$(comm -23 <(echo "$listed") <(echo "$installed"))"

  log "$label"
  report_missing "$file" "$removed" "$other"

  if [[ -z $added ]]; then
    printf '  no untracked packages\n'
    return
  fi
  count="$(wc -l <<<"$added")"

  if [[ $MODE == report ]]; then
    printf '  \033[1;33muntracked (%s):\033[0m\n' "$count"
    sed 's/^/    /' <<<"$added"
    printf '  --apply to walk these one at a time, --apply-all to take them all\n'
    return
  fi

  [[ $MODE == apply-all ]] && bulk=1

  printf '  \033[1;33m%s untracked package(s)\033[0m\n' "$count"

  local pkgs=()
  mapfile -t pkgs <<<"$added"

  for pkg in "${pkgs[@]}"; do
    ((++n))
    if ((!bulk)); then
      printf '    [%d/%d] add %s? [y/n/a=all/q=skip rest] ' "$n" "$count" "$pkg"
      # EOF (piped input running dry) means stop, not append.
      read -r ans || { printf '\n'; break; }
      case "$ans" in
        y|Y) ;;
        a|A) bulk=1 ;;
        q|Q) printf '    skipping the rest of %s\n' "$label"; break ;;
        *)   continue ;;
      esac
    fi
    append_pkg "$file" "$pkg"
    printf '    + %s\n' "$pkg"
  done

  grep -qxF "$MARKER" "$file" && printf '  see the "unsorted" section at the end of %s\n' "$file"
}

OFFICIAL=packages/official-repos.txt
AUR=packages/aur.txt

((DO_OFFICIAL)) && reconcile "$OFFICIAL" 'pacman -Qqen' 'Official repos' "$AUR"
((DO_AUR))      && reconcile "$AUR"      'pacman -Qqem' 'AUR'            "$OFFICIAL"
exit 0
