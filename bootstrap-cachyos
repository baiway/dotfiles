#!/usr/bin/env bash
# Bootstrap a fresh CachyOS install. Idempotent — safe to re-run.
set -euo pipefail

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DOTFILES"

log() { printf '\n\033[1;34m==>\033[0m %s\n' "$*"; }

# Strip comments/blank lines from a package list.
pkglist() { grep -vE '^\s*(#|$)' "$1" | sed 's/#.*//' | tr -d ' '; }

# --- 1. shelly ---------------------------------------------------------------
# `shelly` is a modern package manager for Arch Linux designed to be a more user-friendly
# alternative. It has a CLI and GUI, and interfaces directly with `libalpm`, the same
# low-level package manager used by `pacman`. Since `pacman` ships with all Arch-based
# distributions, `shelly` can safely be installed as follows (even though it is currently
# shipped with CachyOS by default):
if ! command -v shelly >/dev/null 2>&1; then
  log "shelly not found — installing it"
  sudo pacman -S --needed --noconfirm shelly
fi

# --- 2. official repos -------------------------------------------------------
log "Installing packages from the official repos"
# `--upgrade` makes this idempotent: already-installed packages are upgraded
# rather than treated as an error (the equivalent of pacman's --needed).
mapfile -t REPO_PKGS < <(pkglist packages/official-repos.txt)
shelly install --no-confirm --upgrade "${REPO_PKGS[@]}"

# --- 3. AUR ------------------------------------------------------------------
# `shelly aur install` builds from the AUR directly
mapfile -t AUR_PKGS < <(pkglist packages/aur.txt)

if ((${#AUR_PKGS[@]})); then
  log "Fetching AUR PKGBUILDs for: ${AUR_PKGS[*]}"
  # Fetch PKGBUILD as JSON for each AUR package. Used to check against pre-installed
  # versions to save unnecessarily downloading pre-installed packages. Also used to
  # display to the user in review step below.
  aur_json="$(shelly aur search-pkgbuild "${AUR_PKGS[@]}" --json)"

  AUR_TODO=()
  for pkg in "${AUR_PKGS[@]}"; do
    pkgbuild="$(jq -r --arg n "$pkg" '.[] | select(.Name==$n) | .PkgBuild' <<<"$aur_json")"
    if [[ -z $pkgbuild ]]; then
      log "  WARNING: no PKGBUILD returned for $pkg — will attempt install anyway"
      AUR_TODO+=("$pkg"); continue
    fi
    want="$(grep -oP '^pkgver=\K.*' <<<"$pkgbuild" | head -1 | tr -d "\"'")"
    want+="-$(grep -oP '^pkgrel=\K.*' <<<"$pkgbuild" | head -1 | tr -d "\"'")"
    have="$(pacman -Q "$pkg" 2>/dev/null | awk '{print $2}')"
    if [[ $want != -* && $want == "$have" ]]; then
      log "  $pkg $have is up to date — skipping"
    else
      AUR_TODO+=("$pkg")
    fi
  done

  if ((${#AUR_TODO[@]})); then
    log "Reviewing PKGBUILDs for: ${AUR_TODO[*]}"
    # Most of these fetch a vendor binary from a third-party URL. Read before building!
    # Prefer `bat` (syntax-highlighted, installed from the official repos above) as
    # the pager; fall back to $PAGER/less if it isn't there yet.
    if command -v bat >/dev/null 2>&1; then
      pkgbuild_pager=(bat --language=bash --style=plain --paging=always)
    else
      pkgbuild_pager=("${PAGER:-less}")
    fi
    # Show the PKGBUILDs under a clear header.
    # `|| true`: quitting the pager early (e.g. `q` in less) sends SIGPIPE up the
    # pipe, and pipefail + set -e would otherwise abort the whole run.
    jq -r --args '
      .[] | select(.Name as $n | $ARGS.positional | index($n)) |
      "# ==================== PKGBUILD: \(.Name) ====================\n\n\(.PkgBuild)\n"
    ' <<<"$aur_json" "${AUR_TODO[@]}" | "${pkgbuild_pager[@]}" || true

    # `|| reply=n`: a bare `read` returning non-zero on EOF (Ctrl-D / piped stdin)
    # would trip set -e before the branch below; default to "no" instead.
    read -rp $'\nProceed with AUR install? [y/N] ' reply || reply=n
    if [[ ${reply,,} == y* ]]; then
      log "Installing AUR packages"
      shelly aur install --no-confirm "${AUR_TODO[@]}"
    else
      log "Skipped AUR packages. Re-run this script to try again."
    fi
  else
    log "All AUR packages are up to date — nothing to build."
  fi
fi

# --- 3b. Proton Mail Bridge --------------------------------------------------
# Proton ships an official `PKGBUILD` that repackages their prebuilt `.deb` (no source
# build; the `.deb` is sha256-pinned inside that `PKGBUILD`). Shelly is currently
# raising false-positive security issues with the AUR package, so this is just a
# work-around for now.
# The PKGBUILD is tiny (~1 KB), so we grab it first, read its version, and only download
# the large `.deb` and rebuild when it's newer than what's installed (keeps re-runs cheap
# and idempotent).
log "Checking Proton Mail Bridge (Proton's official PKGBUILD)"
bridge_build="$(mktemp -d)"
if curl -fsSL https://proton.me/download/bridge/PKGBUILD -o "$bridge_build/PKGBUILD"; then
  # Parse (don't execute) the version out of the freshly fetched PKGBUILD.
  bridge_ver="$(grep -oP '^pkgver=\K.*' "$bridge_build/PKGBUILD" || true)"
  bridge_rel="$(grep -oP '^pkgrel=\K.*' "$bridge_build/PKGBUILD" || true)"
  installed_ver="$(pacman -Q protonmail-bridge-bin 2>/dev/null | awk '{print $2}' || true)"
  if [[ -n $bridge_ver && "$bridge_ver-$bridge_rel" != "$installed_ver" ]]; then
    log "Building Proton Mail Bridge $bridge_ver-$bridge_rel (installed: ${installed_ver:-none})"
    # makepkg refuses to run as root and calls sudo pacman -U itself for -i.
    ( cd "$bridge_build" && makepkg -si --noconfirm ) \
      || log "WARNING: protonmail-bridge-bin build failed — re-run to retry"
  else
    log "  protonmail-bridge-bin $installed_ver is up to date — skipping"
  fi
else
  log "WARNING: couldn't fetch Proton Mail Bridge PKGBUILD — skipping"
fi
rm -rf "$bridge_build"

# --- 4. Claude Code ----------------------------------------------------------
# Use official installer as the AUR package disable Claude Code's self-update.
if ! command -v claude >/dev/null 2>&1; then
  log "Installing Claude Code"
  curl -fsSL https://claude.ai/install.sh | bash
fi

# --- 5. Python ---------------------------------------------------------------
# Astral's `uv` comes from the "official repos" section above.
# `|| true`: don't let a hiccup here abort the rest of the bootstrap.
log "Installing Python 3.14 via uv"
uv python install 3.14 || true

# --- 6. Helix ----------------------------------------------------------------
# On Arch the binary is `helix`; via Homebrew it's `hx`. The shared gitconfig
# sets `editor = hx`, so expose an `hx` pointing at the real binary. Use
# /usr/local/bin (always on PATH, including the `sh -c` git runs for its editor)
# rather than ~/.local/bin, which isn't on PATH by default here.
if command -v helix >/dev/null 2>&1; then
  log "Linking hx -> helix in /usr/local/bin"
  sudo ln -sf "$(command -v helix)" /usr/local/bin/hx
fi

# --- 7. stow -----------------------------------------------------------------
PACKAGES=(git fish ssh helix ghostty)

# Pre-create ~/.ssh as a real dir (mode 700) so stow symlinks ~/.ssh/config into
# it rather than folding the whole ~/.ssh into one symlink pointing at the repo.
# Otherwise SSH keys generated later (per SETUP.md) would land inside the repo.
# `connections/` holds the ControlPath sockets referenced by ssh/.ssh/config.
mkdir -p "$HOME/.ssh/connections"
chmod 700 "$HOME/.ssh"

# Stow refuses to overwrite a real (non-symlink) file, and a fresh CachyOS
# install ships some of these targets already (notably ~/.config/fish/config.fish).
# Move any such file aside so stow can take over; the original is preserved as
# <file>.pre-stow for later inspection. Idempotent: on re-run the targets are
# already symlinks into this repo, so nothing is moved.
log "Backing up any pre-existing config files that would block stow"
for pkg in "${PACKAGES[@]}"; do
  while IFS= read -r -d '' src; do
    target="$HOME/${src#"$pkg"/}"
    if [[ -e $target && ! -L $target ]]; then
      log "  $target -> $target.pre-stow"
      mv "$target" "$target.pre-stow"
    fi
  done < <(find "$pkg" -type f -print0)
done

log "Stowing: ${PACKAGES[*]}"
stow --target="$HOME" --restow "${PACKAGES[@]}"

log "Done. Remaining manual steps are in SETUP.md."
