#!/usr/bin/env bash
# Detects the operating system and hands off to the platform-specific bootstrap script.
set -euo pipefail

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DOTFILES"

case "$(uname -s)" in
  Darwin)
    exec ./bootstrap-macos "$@"
    ;;
  Linux)
    # Guard against running the CachyOS script on some other distro, where
    # `pacman` may not exist and package names would not resolve.
    if ! command -v pacman >/dev/null 2>&1; then
      echo "error: Linux detected, but this repo only supports Arch-based systems." >&2
      exit 1
    fi
    exec ./bootstrap-cachyos "$@"
    ;;
  *)
    echo "error: unsupported OS: $(uname -s)" >&2
    exit 1
    ;;
esac
